  "homepage": "https://github.com/GrubbyLee/skill-manager",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GrubbyLee/skill-manager.git"
  },
  "bugs": {
    "url": "https://github.com/GrubbyLee/skill-manager/issues"
  },
  "engines": {
    "node": ">=18"
  }
